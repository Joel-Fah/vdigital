# =====================================================================
# VDIGITAL — environment variables
# Copy to .env.local for local dev. NEVER commit .env* (Section 8.1).
# =====================================================================

# --- Database (Neon serverless Postgres) ------------------------------
# Pooled connection string used by the app at runtime.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Direct (non-pooled) connection used by `prisma migrate`. On Neon this is the
# same host without the "-pooler" segment. Falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# --- Auth.js ----------------------------------------------------------
AUTH_SECRET=                 # generate with `npx auth secret`
AUTH_TRUST_HOST=true         # required behind Cloudflare/Vercel proxies
ADMIN_BASE_PATH=studio-vd    # obscured admin path (Section 8.2) — NOT "admin"/"login"
ADMIN_EMAIL=                 # seed script creates this single admin user
ADMIN_INITIAL_PASSWORD=      # seed hashes this; change on first login, then clear here

# --- Cloudflare R2 (media storage, S3-compatible) ---------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=               # e.g. https://media.yourdomain.com (bucket public base URL)

# --- Pexels (placeholder images, Section 7) ---------------------------
PEXELS_API_KEY=

# --- Cloudflare Turnstile (bot protection, Section 8.3) ---------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Email (contact-form notifications, e.g. Zoho SMTP) ---------------
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=             # professional mailbox that receives contact alerts

# --- Analytics (optional at launch) -----------------------------------
NEXT_PUBLIC_ANALYTICS_ID=

# --- Public site URL (for canonical/OpenGraph/sitemap) ----------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
